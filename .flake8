[flake8]
# 设置最大行长度
max-line-length = 120

# 忽略特定的文件或目录
exclude = .git,__pycache__,build,dist,.venv,
    remove_search_ip.py,
    shorten_japanese_dropdown.py,
    debug_expired.py,
    add_translations.py,
    debug_app_init.py,
    fix_expiry_date.py,
    check_expiry_date.py,
    shorten_address_mgmt_abbr.py,
    shorten_korean_dropdown.py,
    test_get_expired.py,
    test_app_flow.py,
    check_db.py,
    debug_get_expired.py,
    shorten_japanese_more.py,
    shorten_korean.py,
    update_addr_full.py,
    update_japanese_import_export.py,
    shorten_address_management.py,
    add_invalid_ip.py,
    fix_encoding.py,
    update_addr_networks.py,
    check_translation.py,
    check_db_status.py,
    shorten_japanese_final.py,
    check_dates.py,
    add_more_translations.py,
    add_batch_generate.py,
    fix_translations.py,
    shorten_english.py,
    shorten_japanese.py

# 忽略某些不相关的警告
# E501: line too long
# F401: unused import
# W503: line break before binary operator
# E303: too many blank lines
# W293: blank line contains whitespace
# W291: trailing whitespace
# E122: continuation line missing indentation or outdented
# E128: continuation line under-indented for visual indent
# F821: undefined name
# F841: local variable is assigned to but never used
# F811: redefinition of unused
ignore = E501,F401,W503,E303,W293,W291,E122,E128,F821,F841,F811,W391

# 启用扩展	extend-ignore = D100,D101,D102,D103,D104,D105,D106,D107

# 报告格式
# format = %(path)s:%(row)d:%(col)d: %(code)s %(text)s
